From 67511a2459382b0456efe68f864b28a127d0e58f Mon Sep 17 00:00:00 2001
From: Dmitry Kazakov <dimula73@gmail.com>
Date: Thu, 4 Jun 2026 13:58:38 +0200
Subject: [PATCH] Fix installation of toolutil.dll

It is necessary by the build tools, which have to be installed
for Android builds. We should also make sure that only the
crosscompiled version is installed, not the native one.
---
 source/tools/toolutil/meson.build | 1 +
 1 file changed, 1 insertion(+)

diff --git a/source/tools/toolutil/meson.build b/source/tools/toolutil/meson.build
index 06d863f..3aa7836 100644
--- a/source/tools/toolutil/meson.build
+++ b/source/tools/toolutil/meson.build
@@ -16,6 +16,7 @@ toolutil_lib = library(
   cpp_args: toolutil_cpp_args,
   dependencies: icui18n_dep,
   name_prefix: library_name_prefix,
+  install: true,
 )
 
 if meson.can_run_host_binaries()
