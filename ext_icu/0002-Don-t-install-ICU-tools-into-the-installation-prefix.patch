From afe21f98473747a3706bdcd6bf18f5ba65495e01 Mon Sep 17 00:00:00 2001
From: Dmitry Kazakov <dimula73@gmail.com>
Date: Wed, 20 May 2026 16:54:24 +0200
Subject: [PATCH 2/2] Don't install ICU tools into the installation prefix

Here in Krita we don't use them. They are used while
generating  ICU-data library, though. The funny thing,
these tool require toolutil.dll to run, but this library has
never been installed, so the tools never worked.
---
 source/tools/genbrk/meson.build   | 2 +-
 source/tools/genccode/meson.build | 4 ++--
 source/tools/gencmn/meson.build   | 2 +-
 source/tools/icuinfo/meson.build  | 2 +-
 source/tools/icupkg/meson.build   | 2 +-
 source/tools/pkgdata/meson.build  | 2 +-
 6 files changed, 7 insertions(+), 7 deletions(-)

diff --git a/source/tools/genbrk/meson.build b/source/tools/genbrk/meson.build
index e635029..4004d4d 100644
--- a/source/tools/genbrk/meson.build
+++ b/source/tools/genbrk/meson.build
@@ -5,7 +5,7 @@ genbrk_exe = executable(
   'genbrk',
   sources,
   dependencies: toolutil_dep,
-  install: true,
+  install: false,
 )
 
 meson.override_find_program('genbrk', genbrk_exe)
diff --git a/source/tools/genccode/meson.build b/source/tools/genccode/meson.build
index 878eb8e..c78b982 100644
--- a/source/tools/genccode/meson.build
+++ b/source/tools/genccode/meson.build
@@ -5,7 +5,7 @@ genccode_exe = executable(
   'genccode',
   sources,
   dependencies: toolutil_dep,
-  install: true,
+  install: false,
 )
 
 if meson.can_run_host_binaries()
@@ -15,7 +15,7 @@ else
     'genccode-native',
     'genccode.c',
     dependencies: toolutil_native_dep,
-    native: true,
+    native: false,
   )
 endif
 
diff --git a/source/tools/gencmn/meson.build b/source/tools/gencmn/meson.build
index 68eec60..cd18e26 100644
--- a/source/tools/gencmn/meson.build
+++ b/source/tools/gencmn/meson.build
@@ -5,7 +5,7 @@ gencmn_exe = executable(
   'gencmn',
   sources,
   dependencies: toolutil_dep,
-  install: true,
+  install: false,
 )
 
 meson.override_find_program('gencmn', gencmn_exe)
diff --git a/source/tools/icuinfo/meson.build b/source/tools/icuinfo/meson.build
index d18909a..5107ed4 100644
--- a/source/tools/icuinfo/meson.build
+++ b/source/tools/icuinfo/meson.build
@@ -13,5 +13,5 @@ executable(
   'icuinfo',
   sources,
   dependencies: toolutil_dep,
-  install: true,
+  install: false,
 )
diff --git a/source/tools/icupkg/meson.build b/source/tools/icupkg/meson.build
index 29031bc..57a9239 100644
--- a/source/tools/icupkg/meson.build
+++ b/source/tools/icupkg/meson.build
@@ -5,5 +5,5 @@ icupkg = executable(
   'icupkg',
   sources,
   dependencies: toolutil_dep,
-  install: true,
+  install: false,
 )
diff --git a/source/tools/pkgdata/meson.build b/source/tools/pkgdata/meson.build
index 592a345..951c5e3 100644
--- a/source/tools/pkgdata/meson.build
+++ b/source/tools/pkgdata/meson.build
@@ -5,5 +5,5 @@ pkgdata = executable(
   'pkgdata',
   sources,
   dependencies: toolutil_dep,
-  install: true,
+  install: false,
 )
-- 
