From 9e83e55d8c917ab0d75982df39a1409e790cb64f Mon Sep 17 00:00:00 2001
From: Ivan Yossi <ghevan@gmail.com>
Date: Wed, 10 Jun 2026 20:34:50 -0600
Subject: [PATCH] macos fix non compatible 1014 code

---
 src/lib/OpenEXR/ImfStdIO.cpp | 16 +++++++++++++++-
 1 file changed, 15 insertions(+), 1 deletion(-)

diff --git a/src/lib/OpenEXR/ImfStdIO.cpp b/src/lib/OpenEXR/ImfStdIO.cpp
index c5c4a26..d838d41 100644
--- a/src/lib/OpenEXR/ImfStdIO.cpp
+++ b/src/lib/OpenEXR/ImfStdIO.cpp
@@ -20,6 +20,10 @@
 #    include <span>
 #endif
 
+#if defined(__APPLE__)
+#include <TargetConditionals.h>
+#endif
+
 using namespace std;
 #include "ImfNamespace.h"
 
@@ -37,8 +41,13 @@ make_ifstream (const char* filename)
     return new ifstream (filesystem::path (u8view.begin (), u8view.end ()),
                          ios_base::in | ios_base::binary);
 #else
-    return new ifstream (filesystem::u8path (filename),
+#if defined(__APPLE__) && __MAC_OS_X_VERSION_MAX_ALLOWED >= 101400
+    return new ifstream (filename,
                          ios_base::in | ios_base::binary);
+#else
+    return new ofstream (filesystem::u8path (filename),
+                         ios_base::out | ios_base::binary);
+#endif
 #endif
 }
 
@@ -50,10 +59,15 @@ make_ofstream (const char* filename)
                                             [](char c) -> char8_t { return c; });
     return new ofstream (filesystem::path (u8view.begin (), u8view.end ()),
                          ios_base::out | ios_base::binary);
+#else
+#if defined(__APPLE__) && __MAC_OS_X_VERSION_MAX_ALLOWED >= 101400
+    return new ofstream (filename,
+                         ios_base::out | ios_base::binary);
 #else
     return new ofstream (filesystem::u8path (filename),
                          ios_base::out | ios_base::binary);
 #endif
+#endif
 }
 
 void
